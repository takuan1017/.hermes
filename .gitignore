# ランタイム・ログ（prompt指定）
logs/
sessions/

# Hermes Agent 本体コード（別管理）
hermes-agent/
bin/

# キャッシュ・一時ファイル
audio_cache/
image_cache/
sandboxes/

# cron 登録ファイル（生成物）
cron/

# hooks（ユーザー定義以外、主に生成物）
hooks/

# Hermes バンドルスキル（あかつき以外は追跡しない）
skills/apple/
skills/autonomous-ai-agents/
